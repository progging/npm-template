{
  "name": "npm-template",
  "version": "1.0.0",
  "description": "A template for making NPM packages with TypeScript, tests and GitHub workflows.",
  "source": "dist/main.module.js",
  "module": "dist/main.module.js",
  "main": "src/main.js",
  "unpkg": "dist/main.umd.js",
  "author": "rob@tenk.dev",
  "scripts": {
    "build": "microbundle src/main.ts -o dist/ --name main",
    "dev": "microbundle watch",
    "test": "mocha -r ts-node/register test/**/*.test.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/progging/npm-template"
  },
  "homepage": "https://github.com/progging/npm-template",
  "keywords": [],
  "devDependencies": {
    "@types/chai": "^4.2.12",
    "@types/mocha": "^8.0.2",
    "chai": "^4.2.0",
    "microbundle": "^0.12.3",
    "mocha": "^8.1.1",
    "ts-node": "^8.10.2",
    "typescript": "^3.9.7"
  }
}
